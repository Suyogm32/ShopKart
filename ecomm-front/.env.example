# MongoDB (same database as the seller portal)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>

# Stripe
STRIPE_SK=            # secret key
STRIPE_PK=            # publishable key

# App URL (used for Stripe redirect URLs)
URL=http://localhost:3000/

# AWS SES (order confirmation email — src/app/api/success/SendMail.js)
# Uses the AWS SDK's default credential chain; set these if not using an IAM role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
